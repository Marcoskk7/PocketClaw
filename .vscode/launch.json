{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug AgentLoop (单次消息)",
      "type": "debugpy",
      "request": "launch",
      "module": "nanobot",
      "args": ["agent", "-m", "你好，请介绍一下你自己", "--logs"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Debug AgentLoop (交互模式)",
      "type": "debugpy",
      "request": "launch",
      "module": "nanobot",
      "args": ["agent", "--logs"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ]
}
